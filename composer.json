{
  "name": "vouchmorphn/core",
  "description": "Prestaged ATM Swap System",
  "type": "project",
  "require": {
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^10"
  },
  "autoload": {
    "psr-4": {
      "APP_LAYER\\": "src/APP_LAYER/",
      "BUSINESS_LOGIC_LAYER\\": "src/BUSINESS_LOGIC_LAYER/",
      "DATA_PERSISTENCE_LAYER\\": "src/DATA_PERSISTENCE_LAYER/",
      "CORE_CONFIG\\": "src/CORE_CONFIG/",
      "FACTORY_LAYER\\": "src/FACTORY_LAYER/",
      "INTEGRATION_LAYER\\": "src/INTEGRATION_LAYER/",
      "SECURITY_LAYER\\": "src/SECURITY_LAYER/",
      "DFSP_ADAPTER_LAYER\\": "src/DFSP_ADAPTER_LAYER/",
      "SYSTEM_DAEMONS\\": "src/SYSTEM_DAEMONS/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "TESTS\\": "src/TESTS/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}

