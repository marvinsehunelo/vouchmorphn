{
  "name": "vouchmorphn/core",
  "description": "Prestaged ATM Swap System",
  "type": "project",
  "require": {
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^10"
  },
  "autoload": {
    "psr-4": {
      "Application\\": "src/Application/",
      "Core\\": "src/Core/",
      "Domain\\": "src/Domain/",
      "Infrastructure\\": "src/Infrastructure/",
      "Security\\": "src/Security/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
