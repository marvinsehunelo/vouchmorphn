# CORE_CONFIG/countries/NG/.env_NG

# Country
VM_COUNTRY=NG

# App
APP_ENV=production
APP_DEBUG=false
APP_URL=https://localhost/vouchmorphn/

# PostgreSQL – Swap System (NG)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASS=StrongPassword!

PG_DB_SWAP=swap_system_ng
PG_DB_CAZACOM=cazacom_ng
PG_DB_ZURU=zurubank_ng
PG_DB_SACCUS=saccussalis_ng
PG_DB_ACCESS=access

# API Keys – NG
API_KEY_SWAP=SWAP_SYSTEM_KEY_NG
API_KEY_SACCUS=SACCUS_KEY_NG
API_KEY_ZURU=ZURU_KEY_NG
API_KEY_ACCESS=ACCESS_KEY_NG
API_KEY_CAZACOM=CAZACOM_KEY_NG
