{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "sh -c 'php -S 0.0.0.0:${PORT:-9000} -t /var/www/html/public >/dev/null 2>&1'",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "preDeploy": "",
    "healthcheckPath": "/test.php"
  }
}
