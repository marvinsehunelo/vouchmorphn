# ---------------------------------------------------------
# VouchMorphn - BW Regulatory Sandbox Configuration
# Bank of Botswana - Sandbox Ready
# ---------------------------------------------------------

# Region & Country
VM_COUNTRY=BW
VM_TZ=Africa/Gaborone

# App Environment
APP_ENV=sandbox
APP_DEBUG=true
APP_URL=http://localhost:6060

# PostgreSQL – Swap System (BW)
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=vouchmorphn_user
PG_PASS=StrongPassword!
PG_NAME=swap_system_bw
PG_DB_PARTNER_1=swap_system_partner1
PG_DB_PARTNER_2=swap_system_partner2
PG_DB_PARTNER_3=swap_system_partner3

# API Credentials
API_KEY_SYSTEM=sys_key_2026_sandbox_001
API_KEY_PARTNER_1=partner1_key_2026_sandbox
API_KEY_PARTNER_2=partner2_key_2026_sandbox
API_KEY_PARTNER_3=partner3_key_2026_sandbox
API_KEY_PARTNER_4=partner4_key_2026_sandbox
API_KEY_ZURUBANK=918446212c28e04075df3f4bfa4ae3971091379af233ab69c7ec7e5c2d5b17d9
API_KEY_SACCUSSALIS=ad1927b1aaa09f04241646aa76b2c5d3886552e4f98d34a460602da26c588109 
# Encryption (AES-256-GCM) - Exactly 32 chars
APP_ENCRYPTION_KEY=ThisIsA32CharKeyForAES256GCM2026!

# Mojaloop Integration
MOJALOOP_ENDPOINT=http://localhost:6060
MOJALOOP_CALLBACK_URL=http://localhost:8080/mojaloop/callback
MOJALOOP_DFSP_ID=VOUCHMORPHN

# Participant Configuration
PARTICIPANTS=ALPHA,BRAVO,CHARLIE,CARD,TEST_BANK_A,TEST_BANK_B,TEST_MNO_A,TEST_MNO_B,TEST_DISTRIBUTOR_A,TEST_DISTRIBUTOR_B,ZURUBANK,SACCUSSALIS
DEFAULT_CURRENCY=BWP

# Logging
LOG_LEVEL=debug
LOG_PATH=/opt/lampp/htdocs/vouchmorphn/src/APP_LAYER/logs
LOG_FILE=swap_audit.log

# Regulatory Reporting
REGULATORY_REPORTING_ENABLED=true
REGULATORY_ENDPOINT=http://localhost:8080/api/regulatory/report

# SCA / OTP Configuration
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3
SCA_REQUIRED_FOR_AMOUNT=5000

# Settlement Configuration
SETTLEMENT_BATCH_SIZE=100
SETTLEMENT_INTERVAL_MINUTES=15
LIQUIDITY_THRESHOLD=1000000

# Cache/Redis (Optional)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
