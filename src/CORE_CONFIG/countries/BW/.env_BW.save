DB_ZURU=mysql:host=localhost;dbname=zurubank_bw
DB_CAZACOM=mysql:host=localhost;dbname=cazacom_bw

# API Keys
API_KEY_SWAP=SWAP_SYSTEM_KEY_BW
API_KEY_SACCUS=SACCUS_KEY_BW
API_KEY_ZURU=ZURU_KEY_BW
API_KEY_ACCESS=ACCESS_KEY_BW
API_KEY_CAZACOM=CAZACOM_KEY_BW

