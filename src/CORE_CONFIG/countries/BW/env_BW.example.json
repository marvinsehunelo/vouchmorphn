# RAILWAY ENVIRONMENT VARIABLES
# Railway automatically provides DATABASE_URL - DO NOT SET MANUALLY
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# Application Settings
APP_ENV=production
APP_DEBUG=false
APP_URL=https://vouchmorphn.com

# Database Settings (Fallback for local development)
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=swap_system_bw
DB_USERNAME=postgres
DB_PASSWORD=StrongPassword!

# Individual Database Names (for multi-db apps)
PG_DB_SWAP=swap_system_bw
PG_DB_SACCUS=saccussalis
PG_DB_ZURU=zurubank
PG_DB_CAZA=cazacom

# API Keys (Set these in Railway dashboard)
API_KEY_ZURUBANK=your_zurubank_api_key
API_KEY_SACCUSSALIS=your_saccussalis_api_key

# OAuth2 Credentials (Set in Railway dashboard)
ZURUBANK_CLIENT_ID=your_client_id
ZURUBANK_CLIENT_SECRET=your_client_secret
SACCUSSALIS_CLIENT_ID=your_client_id
SACCUSSALIS_CLIENT_SECRET=your_client_secret

# Encryption Key (IMPORTANT: Generate a random 32-byte key)
APP_ENCRYPTION_KEY=base64:YourRandom32ByteKeyHere

# SMS Gateway (if using external service)
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=VOUCHMORPH
